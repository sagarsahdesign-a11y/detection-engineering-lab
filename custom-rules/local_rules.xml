<!--
  Detection Engineering Lab - Custom Wazuh Rules
  Deploy to: /var/ossec/etc/rules/local_rules.xml
  Rule ID range: 100100-100111
  Author: Detection Engineering Lab
-->

<group name="detection_engineering_lab,">

  <!-- T1110.003 - Brute Force / Password Spraying -->
  <rule id="100100" level="10" frequency="5" timeframe="60">
    <if_matched_sid>60122</if_matched_sid>
    <same_source_ip />
    <description>Multiple Windows logon failures - Possible brute force (T1110)</description>
    <mitre>
      <id>T1110</id>
      <id>T1110.003</id>
    </mitre>
    <group>authentication_failures,windows,</group>
  </rule>

  <!-- T1059.001 - Suspicious PowerShell -->
  <rule id="100101" level="12">
    <field name="win.system.eventID">^4104$</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)(-enc|-EncodedCommand|IEX|DownloadString|Invoke-Mimikatz|FromBase64String)</field>
    <description>Suspicious PowerShell script block detected (T1059.001)</description>
    <mitre>
      <id>T1059</id>
      <id>T1059.001</id>
    </mitre>
    <group>powershell,windows,</group>
  </rule>

  <rule id="1001011" level="12">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(-enc|-EncodedCommand|DownloadString|IEX)</field>
    <description>Suspicious PowerShell command line (T1059.001)</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <group>powershell,windows,</group>
  </rule>

  <!-- T1547.001 - Registry Run Key Persistence -->
  <rule id="100102" level="10">
    <if_sid>61615</if_sid>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)CurrentVersion\\Run</field>
    <description>Registry Run key modified - Possible persistence (T1547.001)</description>
    <mitre>
      <id>T1547</id>
      <id>T1547.001</id>
    </mitre>
    <group>registry,windows,</group>
  </rule>

  <rule id="1001021" level="10">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\reg\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)CurrentVersion\\Run</field>
    <description>reg.exe modifying Run key - Possible persistence (T1547.001)</description>
    <mitre>
      <id>T1547.001</id>
    </mitre>
    <group>registry,windows,</group>
  </rule>

  <!-- T1003.001 - LSASS Credential Dumping -->
  <rule id="100103" level="14">
    <if_sid>61610</if_sid>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)\\lsass\.exe$</field>
    <field name="win.eventdata.grantedAccess" type="pcre2">(?i)0x(1010|1410|143A|1fffff|147a)</field>
    <description>LSASS process access - Possible credential dumping (T1003.001)</description>
    <mitre>
      <id>T1003</id>
      <id>T1003.001</id>
    </mitre>
    <group>credential_access,windows,</group>
  </rule>

  <!-- T1021.001 - RDP Logon -->
  <rule id="100104" level="8">
    <if_sid>60106</if_sid>
    <field name="win.system.eventID">^4624$</field>
    <field name="win.eventdata.logonType">^10$</field>
    <description>Remote Desktop Protocol logon detected (T1021.001)</description>
    <mitre>
      <id>T1021</id>
      <id>T1021.001</id>
    </mitre>
    <group>authentication_success,windows,</group>
  </rule>

  <!-- T1078.003 - Valid Accounts (behavioral) -->
  <rule id="100105" level="6">
    <if_sid>60106</if_sid>
    <field name="win.system.eventID">^4624$</field>
    <field name="win.eventdata.logonType" type="pcre2">^(2|10)$</field>
    <field name="win.eventdata.targetUserName" type="pcre2">(?i)admin</field>
    <time>18:00 - 08:00</time>
    <description>Local admin interactive logon outside business hours (T1078.003)</description>
    <mitre>
      <id>T1078</id>
      <id>T1078.003</id>
    </mitre>
    <group>authentication_success,windows,</group>
  </rule>

  <!-- T1105 - Ingress Tool Transfer -->
  <rule id="100106" level="10">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\certutil\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(-urlcache|-verifyctl|-f\s+http)</field>
    <description>certutil used to download file - Ingress tool transfer (T1105)</description>
    <mitre>
      <id>T1105</id>
    </mitre>
    <group>command_and_control,windows,</group>
  </rule>

  <rule id="1001061" level="10">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\bitsadmin\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)/transfer</field>
    <description>bitsadmin file transfer - Ingress tool transfer (T1105)</description>
    <mitre>
      <id>T1105</id>
    </mitre>
    <group>command_and_control,windows,</group>
  </rule>

  <rule id="1001062" level="10">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\powershell\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(DownloadString|Invoke-WebRequest|DownloadFile|Net\.WebClient)</field>
    <description>PowerShell download cradle - Ingress tool transfer (T1105)</description>
    <mitre>
      <id>T1105</id>
    </mitre>
    <group>command_and_control,windows,</group>
  </rule>

  <!-- T1082 - System Information Discovery (chain) -->
  <rule id="100107" level="6" frequency="3" timeframe="300">
    <if_matched_group>discovery_commands</if_matched_group>
    <same_field>win.eventdata.subjectUserName</same_field>
    <description>Multiple system discovery commands in short window (T1082)</description>
    <mitre>
      <id>T1082</id>
    </mitre>
    <group>discovery,windows,</group>
  </rule>

  <rule id="1001071" level="3">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(systeminfo|hostname|whoami|ipconfig)\.exe$</field>
    <description>System information discovery command executed</description>
    <group>discovery_commands,windows,</group>
  </rule>

  <!-- T1018 - Remote System Discovery -->
  <rule id="100108" level="8">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\net\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(view|group)</field>
    <description>Remote system discovery via net.exe (T1018)</description>
    <mitre>
      <id>T1018</id>
    </mitre>
    <group>discovery,windows,</group>
  </rule>

  <rule id="1001081" level="8">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\nltest\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(/dclist|/dsgetdc)</field>
    <description>Domain controller enumeration via nltest (T1018)</description>
    <mitre>
      <id>T1018</id>
    </mitre>
    <group>discovery,windows,</group>
  </rule>

  <!-- T1047 - WMI Execution -->
  <rule id="100109" level="10">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\wmic\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)process\s+call\s+create</field>
    <description>WMI used to create process (T1047)</description>
    <mitre>
      <id>T1047</id>
    </mitre>
    <group>execution,windows,</group>
  </rule>

  <rule id="1001091" level="10">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\WmiPrvSE\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell)\.exe$</field>
    <description>Child process spawned by WmiPrvSE.exe (T1047)</description>
    <mitre>
      <id>T1047</id>
    </mitre>
    <group>execution,windows,</group>
  </rule>

  <!-- T1055.001 - Process Injection -->
  <rule id="100110" level="12">
    <if_sid>61609</if_sid>
    <field name="win.system.eventID">^8$</field>
    <field name="win.eventdata.sourceImage" type="pcre2">(?i)\\(powershell|wscript|cscript|mshta)\.exe$</field>
    <description>Process injection via CreateRemoteThread from script interpreter (T1055.001)</description>
    <mitre>
      <id>T1055</id>
      <id>T1055.001</id>
    </mitre>
    <group>defense_evasion,windows,</group>
  </rule>

  <!-- T1136.001 - Create Local Account -->
  <rule id="100111" level="10">
    <if_sid>60103</if_sid>
    <description>Local user account created (T1136.001)</description>
    <mitre>
      <id>T1136</id>
      <id>T1136.001</id>
    </mitre>
    <group>account_add,windows,</group>
  </rule>

  <rule id="1001111" level="12">
    <if_sid>60145</if_sid>
    <field name="win.system.eventID">^4732$</field>
    <field name="win.eventdata.targetUserName" type="pcre2">(?i)administrators</field>
    <description>User added to local Administrators group (T1136.001)</description>
    <mitre>
      <id>T1136.001</id>
    </mitre>
    <group>account_add,windows,</group>
  </rule>

</group>
